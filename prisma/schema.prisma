generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

enum MerchantUserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum BusinessStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum BusinessType {
  BUSINESS
  INDIVIDUAL
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  DEVELOPER
  SUPPORT
}

enum ApiKeyMode {
  TEST
  LIVE
}

enum PlanStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CustomerStatus {
  ACTIVE
  DISABLED
}

enum BillingInterval {
  DAY
  WEEK
  MONTH
  YEAR
  CUSTOM
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum WebhookEndpointStatus {
  ACTIVE
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum PortalSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PaymentMethodStatus {
  PENDING_SETUP
  ACTIVE
  DISABLED
  EXPIRED
}

enum PaymentMethodType {
  CARD
  BANK_ACCOUNT
  UNKNOWN
}

enum PaymentProvider {
  NOMBA
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAYMENT_PROCESSING
  PAID
  PAYMENT_FAILED
  VOID
  UNCOLLECTIBLE
}

enum PaymentAttemptStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REQUIRES_ACTION
  ABANDONED
}

enum DunningAttemptStatus {
  SCHEDULED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXHAUSTED
}

model MerchantUser {
  id                    String             @id @default(uuid())
  email                 String
  name                  String
  passwordHash          String
  status                MerchantUserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt       DateTime?
  verificationTokenHash String?
  verificationSentAt    DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  ownedBusinesses     Business[]                   @relation("BusinessOwner")
  memberships         BusinessMember[]
  sessions            MerchantSession[]
  passwordResetTokens MerchantPasswordResetToken[]

  @@unique([email])
  @@index([status])
}

model MerchantPasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model MerchantSession {
  id                   String    @id @default(uuid())
  userId               String
  refreshTokenHash     String    @unique
  userAgent            String?
  ipAddress            String?
  lastUsedAt           DateTime?
  expiresAt            DateTime
  revokedAt            DateTime?
  rotatedFromSessionId String?
  createdAt            DateTime  @default(now())

  user MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Business {
  id                         String         @id @default(uuid())
  ownerUserId                String
  type                       BusinessType
  name                       String
  status                     BusinessStatus @default(PENDING_VERIFICATION)
  businessName               String?
  businessRegistrationNumber String?
  taxId                      String?
  website                    String?
  legalName                  String?
  contactName                String
  contactEmail               String
  contactPhone               String
  country                    String         @default("NG")
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  owner           MerchantUser     @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members         BusinessMember[]
  apiKeys         ApiKey[]
  plans           Plan[]
  customers       Customer[]
  paymentMethods  PaymentMethod[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  paymentAttempts PaymentAttempt[]
  dunningAttempts DunningAttempt[]
  webhookEndpoints WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  portalSessions PortalSession[]
  auditLogs       AuditLog[]

  @@index([ownerUserId])
  @@index([status])
  @@index([type])
}

model BusinessMember {
  id         String             @id @default(uuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(OWNER)
  createdAt  DateTime           @default(now())

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId, role])
}

model ApiKey {
  id         String     @id @default(uuid())
  businessId String
  name       String
  mode       ApiKeyMode
  prefix     String
  keyHash    String     @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([mode])
  @@index([prefix])
}

model Plan {
  id            String          @id @default(uuid())
  businessId    String
  mode          ApiKeyMode      @default(TEST)
  name          String
  code          String
  amountMinor   Int
  currency      String          @default("NGN")
  interval      BillingInterval
  intervalCount Int             @default(1)
  trialDays     Int             @default(0)
  status        PlanStatus      @default(ACTIVE)
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  invoiceItems  InvoiceItem[]

  @@unique([businessId, mode, code])
  @@index([businessId, status])
  @@index([businessId, mode])
}

model Customer {
  id                String         @id @default(uuid())
  businessId        String
  mode              ApiKeyMode     @default(TEST)
  email             String
  name              String?
  phone             String?
  externalReference String?
  status            CustomerStatus @default(ACTIVE)
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  paymentMethods  PaymentMethod[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  paymentAttempts PaymentAttempt[]
  dunningAttempts DunningAttempt[]
  portalSessions  PortalSession[]

  @@unique([businessId, mode, email])
  @@unique([businessId, mode, externalReference])
  @@index([businessId])
  @@index([businessId, mode])
  @@index([businessId, status])
}

model PaymentMethod {
  id                             String              @id @default(uuid())
  businessId                     String
  customerId                     String
  mode                           ApiKeyMode          @default(TEST)
  provider                       PaymentProvider     @default(NOMBA)
  type                           PaymentMethodType   @default(UNKNOWN)
  status                         PaymentMethodStatus @default(PENDING_SETUP)
  providerSetupReference         String?
  providerCustomerReference      String?
  providerPaymentMethodReference String?
  brand                          String?
  last4                          String?
  expMonth                       Int?
  expYear                        Int?
  reusable                       Boolean             @default(false)
  metadata                       Json?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  paymentAttempts PaymentAttempt[]

  @@unique([businessId, mode, provider, providerSetupReference])
  @@index([businessId, mode])
  @@index([customerId, status])
  @@index([provider, providerSetupReference])
}

model Subscription {
  id                 String             @id @default(uuid())
  businessId         String
  customerId         String
  planId             String
  paymentMethodId    String
  mode               ApiKeyMode         @default(TEST)
  status             SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime?
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  cancelledAt        DateTime?
  pausedAt           DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  plan            Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  paymentMethod   PaymentMethod    @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  paymentAttempts PaymentAttempt[]
  dunningAttempts DunningAttempt[]

  @@index([businessId, mode])
  @@index([businessId, mode, status])
  @@index([customerId, status])
  @@index([planId])
  @@index([nextBillingAt])
}

model Invoice {
  id              String        @id @default(uuid())
  businessId      String
  subscriptionId  String
  customerId      String
  mode            ApiKeyMode    @default(TEST)
  status          InvoiceStatus @default(DRAFT)
  amountDueMinor  Int
  amountPaidMinor Int           @default(0)
  currency        String        @default("NGN")
  dueAt           DateTime?
  paidAt          DateTime?
  periodStart     DateTime
  periodEnd       DateTime
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription    Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items           InvoiceItem[]
  attempts        PaymentAttempt[]
  dunningAttempts DunningAttempt[]

  @@index([businessId, mode])
  @@index([businessId, mode, status])
  @@index([subscriptionId])
  @@index([customerId])
  @@index([dueAt])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  businessId     String
  invoiceId      String
  subscriptionId String
  planId         String
  description    String
  amountMinor    Int
  currency       String   @default("NGN")
  periodStart    DateTime
  periodEnd      DateTime
  metadata       Json?
  createdAt      DateTime @default(now())

  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([invoiceId])
  @@index([subscriptionId])
  @@index([planId])
}

model PaymentAttempt {
  id                String               @id @default(uuid())
  businessId        String
  subscriptionId    String
  invoiceId         String
  customerId        String
  paymentMethodId   String
  mode              ApiKeyMode           @default(TEST)
  provider          PaymentProvider      @default(NOMBA)
  amountMinor       Int
  currency          String               @default("NGN")
  status            PaymentAttemptStatus @default(PENDING)
  providerReference String?
  failureReason     String?
  attemptNumber     Int
  requestedAt       DateTime             @default(now())
  processedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription  Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, attemptNumber])
  @@unique([provider, providerReference])
  @@index([businessId, mode])
  @@index([businessId, mode, status])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([customerId])
}

model DunningAttempt {
  id             String               @id @default(uuid())
  businessId     String
  subscriptionId String
  invoiceId      String
  customerId     String
  mode           ApiKeyMode           @default(TEST)
  status         DunningAttemptStatus @default(SCHEDULED)
  attemptNumber  Int
  scheduledAt    DateTime
  processedAt    DateTime?
  failureReason  String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, attemptNumber])
  @@index([businessId, mode])
  @@index([businessId, mode, status])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([scheduledAt])
}

model IdempotencyKey {
  id           String    @id @default(uuid())
  businessId   String
  key          String
  method       String
  route        String
  requestHash  String
  responseBody Json?
  statusCode   Int?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([businessId, method, route, key])
  @@index([businessId])
  @@index([createdAt])
}

model WebhookEvent {
  id              String             @id @default(uuid())
  provider        String
  mode            ApiKeyMode         @default(TEST)
  providerEventId String
  eventType       String?
  status          WebhookEventStatus @default(RECEIVED)
  rawBody         String
  rawBodyHash     String
  payload         Json
  headers         Json
  signature       String?
  providerSentAt  DateTime?
  receivedAt      DateTime           @default(now())
  processedAt     DateTime?
  failureReason   String?

  @@unique([provider, mode, providerEventId])
  @@index([provider, mode])
  @@index([provider, eventType])
  @@index([status])
  @@index([receivedAt])
  @@index([rawBodyHash])
}

model WebhookEndpoint {
  id          String                @id @default(uuid())
  businessId  String
  url         String
  description String?
  secret      String
  events      String[]
  status      WebhookEndpointStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  disabledAt  DateTime?

  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([businessId, status])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String                @id @default(uuid())
  businessId      String
  endpointId      String
  eventId         String
  eventType       String
  payload         Json
  status          WebhookDeliveryStatus @default(PENDING)
  attempts        Int                   @default(0)
  nextAttemptAt   DateTime?
  lastAttemptAt   DateTime?
  deliveredAt     DateTime?
  lastStatusCode  Int?
  lastResponseBody String?
  failureReason   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, eventId])
  @@index([businessId, status])
  @@index([endpointId, status])
  @@index([eventType])
  @@index([nextAttemptAt])
}

model PortalSession {
  id         String              @id @default(uuid())
  businessId String
  customerId String
  mode       ApiKeyMode          @default(TEST)
  tokenHash  String              @unique
  status     PortalSessionStatus @default(ACTIVE)
  returnUrl  String?
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  metadata   Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, mode])
  @@index([customerId, status])
  @@index([expiresAt])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  businessId String
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, action])
  @@index([entity, entityId])
}
