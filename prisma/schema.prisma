generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

enum MerchantUserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum BusinessStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum BusinessType {
  BUSINESS
  INDIVIDUAL
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  DEVELOPER
  SUPPORT
}

enum ApiKeyMode {
  TEST
  LIVE
}

enum PlanStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BillingInterval {
  DAY
  WEEK
  MONTH
  YEAR
  CUSTOM
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

model MerchantUser {
  id                    String             @id @default(uuid())
  email                 String
  name                  String
  passwordHash          String
  status                MerchantUserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt       DateTime?
  verificationTokenHash String?
  verificationSentAt    DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  ownedBusinesses Business[]       @relation("BusinessOwner")
  memberships     BusinessMember[]
  sessions        MerchantSession[]
  passwordResetTokens MerchantPasswordResetToken[]

  @@unique([email])
  @@index([status])
}

model MerchantPasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model MerchantSession {
  id                   String    @id @default(uuid())
  userId               String
  refreshTokenHash     String    @unique
  userAgent            String?
  ipAddress            String?
  lastUsedAt           DateTime?
  expiresAt            DateTime
  revokedAt            DateTime?
  rotatedFromSessionId String?
  createdAt            DateTime  @default(now())

  user MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Business {
  id                         String         @id @default(uuid())
  ownerUserId                String
  type                       BusinessType
  name                       String
  status                     BusinessStatus @default(PENDING_VERIFICATION)
  businessName               String?
  businessRegistrationNumber String?
  taxId                      String?
  website                    String?
  legalName                  String?
  contactName                String
  contactEmail               String
  contactPhone               String
  country                    String         @default("NG")
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  owner       MerchantUser    @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     BusinessMember[]
  apiKeys     ApiKey[]
  plans       Plan[]
  customers   Customer[]
  auditLogs   AuditLog[]

  @@index([ownerUserId])
  @@index([status])
  @@index([type])
}

model BusinessMember {
  id         String             @id @default(uuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(OWNER)
  createdAt  DateTime           @default(now())

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     MerchantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId, role])
}

model ApiKey {
  id         String     @id @default(uuid())
  businessId String
  name       String
  mode       ApiKeyMode
  prefix     String
  keyHash    String     @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([mode])
  @@index([prefix])
}

model Plan {
  id            String          @id @default(uuid())
  businessId    String
  name          String
  code          String
  amountMinor   Int
  currency      String          @default("NGN")
  interval      BillingInterval
  intervalCount Int             @default(1)
  trialDays     Int             @default(0)
  status        PlanStatus      @default(ACTIVE)
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, code])
  @@index([businessId, status])
}

model Customer {
  id                String   @id @default(uuid())
  businessId        String
  email             String
  name              String?
  phone             String?
  externalReference String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, email])
  @@unique([businessId, externalReference])
  @@index([businessId])
}

model IdempotencyKey {
  id            String   @id @default(uuid())
  businessId    String
  key           String
  method        String
  route         String
  requestHash   String
  responseBody  Json?
  statusCode    Int?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@unique([businessId, method, route, key])
  @@index([businessId])
  @@index([createdAt])
}

model WebhookEvent {
  id              String             @id @default(uuid())
  provider        String
  providerEventId String
  eventType       String?
  status          WebhookEventStatus @default(RECEIVED)
  rawBody         String
  rawBodyHash     String
  payload         Json
  headers         Json
  signature       String?
  providerSentAt  DateTime?
  receivedAt      DateTime           @default(now())
  processedAt     DateTime?
  failureReason   String?

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([status])
  @@index([receivedAt])
  @@index([rawBodyHash])
}

model AuditLog {
  id         String   @id @default(uuid())
  businessId String
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, action])
  @@index([entity, entityId])
}
