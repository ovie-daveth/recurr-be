NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recurr_db?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=""
REDIS_PASSWORD=""
WORKER_DEFAULT_MODE="TEST"
WORKER_RUN_LIMIT=50
WORKER_CONCURRENCY=2
WORKER_BILLING_INTERVAL_MS=60000
WORKER_DUNNING_INTERVAL_MS=60000
WORKER_WEBHOOK_INTERVAL_MS=60000
WORKER_SKIP_TRANSACTION_VERIFICATION=true
WEBHOOK_RETRY_DELAYS_MINUTES=1,5,30,120,720

API_KEY_PREFIX="sk_test"
LIVE_API_KEY_PREFIX="sk_live"
MERCHANT_SESSION_SECRET="replace-this-with-a-secure-merchant-session-secret"
MERCHANT_ACCESS_TOKEN_TTL_SECONDS=900
MERCHANT_REFRESH_TOKEN_TTL_DAYS=30
MERCHANT_PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Live Nomba credentials. Used when Recurr mode/API key is LIVE.
NOMBA_ENVIRONMENT="TEST"
NOMBA_CLIENT_ID=""
NOMBA_CLIENT_SECRET=""
NOMBA_ACCOUNT_ID=""
NOMBA_BASE_URL="https://api.nomba.com/v1"

# Sandbox Nomba credentials. Used when Recurr mode/API key is TEST.
NOMBA_TEST_CLIENT_ID=""
NOMBA_TEST_CLIENT_SECRET=""
NOMBA_TEST_ACCOUNT_ID=""
NOMBA_TEST_BASE_URL="https://sandbox.nomba.com/v1"

NOMBA_MOCK=false
NOMBA_DEBUG=false
NOMBA_TOKEN_ISSUE_PATH="/auth/token/issue"
# NOMBA_CHECKOUT_PATH="/sandbox/checkout/order"
NOMBA_CHECKOUT_PATH="/checkout/order"
NOMBA_TOKEN_CHARGE_PATH="/checkout/tokenized-card-payment"
NOMBA_TRANSACTION_LOOKUP_PATH="/checkout/transaction"
NOMBA_TRANSACTION_ID_TYPE="orderReference"
NOMBA_TOKEN_REFRESH_WINDOW_MS=300000
NOMBA_WEBHOOK_SECRET="NombaHackathon2026"
NOMBA_WEBHOOK_SIGNING_KEY=""
NOMBA_WEBHOOK_SIGNATURE_HEADER="nomba-signature"
NOMBA_WEBHOOK_TIMESTAMP_HEADER="x-nomba-timestamp"
NOMBA_WEBHOOK_REQUIRE_TIMESTAMP=false
NOMBA_WEBHOOK_EVENT_ID_HEADER=""
NOMBA_WEBHOOK_MODE="TEST"
NOMBA_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

APP_BASE_URL="http://localhost:5000"
FRONTEND_BASE_URL="http://localhost:5173"
PORTAL_BASE_URL="http://localhost:5173"
EMAIL_VERIFICATION_BASE_URL="http://localhost:5173"
PASSWORD_RESET_BASE_URL="http://localhost:5173"

# Email delivery. In development, signup still works without SMTP and logs the
# verification link. In production, SMTP_HOST and MAIL_FROM are required.
MAIL_FROM="Recurr <no-reply@recurr.local>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""

# Demo seed script. DEMO_WEBHOOK_URL is optional.
DEMO_MERCHANT_EMAIL="demo@recurr.test"
DEMO_MERCHANT_PASSWORD="DemoPass123!"
DEMO_BUSINESS_NAME="Recurr Demo Studio"
DEMO_PLAN_CODE="pro_monthly_demo"
DEMO_CUSTOMER_EMAIL="demo-customer@example.com"
DEMO_CUSTOMER_EXTERNAL_REF="demo-customer-001"
DEMO_WEBHOOK_URL=""
